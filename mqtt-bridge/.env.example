# Copy to .env and edit for your environment
# cp .env.example .env

# MQTT topic prefix (optional, default: astrophoto)
MQTT_PREFIX=astrophoto

# Timezone
TZ=America/Santiago

# How many raw files (ARW/FITS) to keep on the Pi before pruning oldest
# ARW ~24MB, so 200 = ~5GB. Pi has 58GB card so this is conservative.
SHOTS_KEEP=200
